# BlackSand dashboard — local Express host configuration.
# Copy this file to `.env` and adjust as needed. `.env` is gitignored (never commit it).
# The server also runs with no .env at all, using the defaults below.

# Host/port for the optional Express server
HOST=0.0.0.0
PORT=3000

# SQLite database file location (Phase 1). Relative paths resolve from the project
# root, not the terminal working directory. An absolute path is honoured as-is.
# Default when unset: data/dashboard.db
SQLITE_DB_PATH=data/dashboard.db

# ─────────────────────────────────────────────────────────────────────────────
# Monday.com integration. `.env` is loaded automatically at startup (server/config/
# load-env.js) if present; externally-injected env vars always take precedence.
# API keys must live ONLY on the server (in your gitignored .env), never in frontend JS.
# Nothing is hardcoded in code; the server reads it all from the environment / mapping.
# ─────────────────────────────────────────────────────────────────────────────

# Secret — the Monday API token. CANONICAL name is MONDAY_API_KEY. NEVER commit a value.
# (MONDAY_API_TOKEN is accepted as a DEPRECATED alias, with a value-free warning; please
#  rename it to MONDAY_API_KEY.)
# MONDAY_API_KEY=replace_with_your_monday_api_key
#
# TOKEN ROTATION (handover): to rotate, generate a new token in Monday
# (Admin → Connections/API, or a service account's Developer → My Access Tokens),
# paste ONLY into your local `.env` (never a commit/PR/log/screenshot), restart the
# server/CLI, then revoke the old token in Monday. The token is read from the environment
# only, is non-enumerable on the config object, and is never printed. No code change is
# needed to rotate. If a token is ever exposed, revoke it in Monday immediately.

# Monday API endpoint + version header (defaults shown; usually leave unset).
# MONDAY_API_URL=https://api.monday.com/v2
# MONDAY_API_VERSION=2024-10

# Board → column → canonical mapping file (copy config/monday-mapping.example.json →
# config/monday-mapping.json, which is gitignored). BOARD IDs and COLUMN IDs live in
# that JSON — NOT in env vars. (Any MONDAY_*_BOARD_ID variables in .env are ignored.)
# MONDAY_MAPPING_FILE=config/monday-mapping.json
# MONDAY_WORKSPACE_ID=

# Sync behaviour — OFF by default (safe offline). A real Monday→SQLite sync requires
# BOTH of these plus `npm run monday:sync -- --confirm`.
# MONDAY_SYNC_ENABLED=false
# MONDAY_DRY_RUN=true

# Timing / resilience (defaults shown).
# MONDAY_POLL_INTERVAL_MS=3600000      # hourly
# MONDAY_REQUEST_TIMEOUT_MS=30000
# MONDAY_RETRY_COUNT=3
# MONDAY_RETRY_BASE_MS=500
# MONDAY_RATE_LIMIT_PER_MIN=60
# MONDAY_MAX_PAGES=50
# MONDAY_BATCH_SIZE=100

# Last-known-good safety (global defaults; per-board `safety` in the mapping overrides).
# MONDAY_ALLOW_EMPTY_BOARD=false        # reject an empty board that previously had data
# MONDAY_MAX_RECORD_DROP_PERCENT=50     # reject a sync that drops >N% of records
# MONDAY_MIN_ACCEPTED_RECORDS=0         # reject a sync with fewer accepted rows than this

# Diagnostics.
# MONDAY_LOG_LEVEL=info                 # error | warn | info | debug
# MONDAY_ENV=development
